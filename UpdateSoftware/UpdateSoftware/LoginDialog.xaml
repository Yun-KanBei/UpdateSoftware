<Window x:Class="UpdateSoftware.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="身份验证"
        Width="389"
        Height="280"
        Icon="/APP.ico"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#FF2D2D2D"
        FontFamily="Microsoft YaHei">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="请输入您的身份信息"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#FFE0E0E0"
                   Margin="0,0,0,15" />

        <!-- 用户名 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="用户名:"
                       Width="60"
                       VerticalAlignment="Center"
                       Foreground="#FFC0C0C0" />
            <TextBox x:Name="TxtUserName"
                     Width="250"
                     Height="28"
                     Background="#FF3D3D3D"
                     Foreground="#FFE0E0E0"
                     BorderBrush="#FF555555"
                     BorderThickness="1"
                     Padding="4,0" />
        </StackPanel>

        <!-- 密码 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="密码:"
                       Width="60"
                       VerticalAlignment="Center"
                       Foreground="#FFC0C0C0" />
            <PasswordBox x:Name="PwdPassword"
                         Width="250"
                         Height="28"
                         Background="#FF3D3D3D"
                         Foreground="#FFE0E0E0"
                         BorderBrush="#FF555555"
                         BorderThickness="1" />
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnLogin"
                    Content="登录"
                    Width="80"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="#FF0078D4"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnLogin_Click" />
            <Button Content="取消"
                    Width="80"
                    Height="32"
                    Background="#FF555555"
                    Foreground="#FFE0E0E0"
                    BorderThickness="0"
                    IsCancel="True" />
        </StackPanel>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="4"
                   x:Name="TxtError"
                   Foreground="#FFFF4444"
                   FontSize="12"
                   Margin="0,10,0,0"
                   Visibility="Collapsed" />
    </Grid>
</Window>

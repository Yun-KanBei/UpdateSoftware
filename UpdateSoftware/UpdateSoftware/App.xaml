<Application x:Class="UpdateSoftware.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:UpdateSoftware">
    <Application.Resources>
        <!-- 暗色主题颜色资源 -->
        <SolidColorBrush x:Key="Transparent" Color="Transparent"/>
        <SolidColorBrush x:Key="PageText" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#999999"/>
        <SolidColorBrush x:Key="TextMuted" Color="#777777"/>
        <SolidColorBrush x:Key="ControlBg" Color="#2D2D30"/>
        <SolidColorBrush x:Key="SideBarBg" Color="#252526"/>
        <SolidColorBrush x:Key="InputBg" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="BorderColor" Color="#444444"/>
        <SolidColorBrush x:Key="AccentColor" Color="#007ACC"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#388E3C"/>
        <SolidColorBrush x:Key="DangerColor" Color="#D32F2F"/>
    </Application.Resources>
</Application>

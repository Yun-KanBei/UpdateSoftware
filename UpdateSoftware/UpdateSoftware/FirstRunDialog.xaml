<Window x:Class="UpdateSoftware.FirstRunDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="首次运行设置" Height="200" Width="440"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Icon="/APP.ico"
        Background="#FF1E1E1E"
        Foreground="#E0E0E0"
        FontSize="13">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="请选择关闭窗口时的默认行为："
                   Foreground="#E0E0E0"
                   FontSize="14"
                   Margin="0,10,0,0"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Orientation="Horizontal" Margin="0,15,0,15">
            <Button x:Name="BtnExit" Width="150" Height="38"
                    Content="结束程序"
                    Cursor="Hand"
                    Foreground="White"
                    Background="#3C3C3C"
                    BorderBrush="#444444"
                    BorderThickness="1"
                    FontSize="13"
                    Margin="0,0,15,0"
                    Click="BtnExit_Click"/>
            <Button x:Name="BtnTray" Width="150" Height="38"
                    Content="最小化到系统托盘"
                    Cursor="Hand"
                    Foreground="White"
                    Background="#007ACC"
                    BorderBrush="#007ACC"
                    BorderThickness="1"
                    FontSize="13"
                    Margin="15,0,0,0"
                    Click="BtnTray_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="选择后可在「参数设定」页面随时更改"
                   Foreground="#777777"
                   FontSize="11"
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
